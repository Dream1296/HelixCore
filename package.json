{
  "name": "dreams",
  "version": "1.0.0",
  "description": "文件存放规范 src/config  配置文件夹 src/config/db  数据库连接配置文件 src/routes   路由处理 src/controllers 控制器 src/services  服务 src/models  数据模型 src/middlewares  中间件 src/utils  工具函数",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "clean": "rimraf dist",
    "build": "webpack",
    "copy-js": "copyfiles -u 1 \"src/**/*.js\" dist",
    "start": "node dist/main.js",
    "test": "node esbuild.config.js",
    "dev": "nodemon --config nodemon.json --exec ts-node-dev -r tsconfig-paths/register src/main.ts",
    "dev_olds": "nodemon --config nodemon.json --exec \"ts-node -r tsconfig-paths/register esbuild.config.ts && node distDev/main.js\"",
    "desv_old": "nodemon --watch src --exec \"ts-node -r tsconfig-paths/register esbuild.config.ts\" && node distDev/main.js",
    "img": " ts-node -r tsconfig-paths/register src/tool/fork/a.ts",
    "ts-run" :"ts-node -r tsconfig-paths/register /tool/*"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.7.2",
    "body-parser": "^1.20.2",
    "canvas": "^3.0.1",
    "chart.js": "^4.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-http2": "^4.13.4",
    "express-mysql-session": "^3.0.2",
    "express-session": "^1.18.0",
    "ffmpeg-static": "^5.2.0",
    "figlet": "^1.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "io-ts": "^2.2.22",
    "ioredis": "^5.4.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.38.0",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.10.1",
    "nodemailer": "^6.9.16",
    "puppeteer": "^23.6.0",
    "request": "^2.88.2",
    "sharp": "^0.33.4",
    "spdy": "^4.0.2",
    "tesseract.js": "^5.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/mysql": "^2.15.26",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "@types/ws": "^8.5.11",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.24.0",
    "esbuild-plugin-node-externals": "^1.0.1",
    "node-polyfill-webpack-plugin": "^4.0.0",
    "nodemon": "^3.1.7",
    "rimraf": "^6.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "keywords": []
}
